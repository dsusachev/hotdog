# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database (Supabase — get credentials from the DB developer)
DB_HOST=your-supabase-host.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.your-project-id
DB_PASSWORD=your-password

# JWT (придумай любую длинную случайную строку)
SECRET_KEY=change-me-in-production

# ML Service (при запуске через Docker менять не нужно)
ML_SERVICE_URL=http://localhost:8001
CONFIDENCE_THRESHOLD=0.5

# External APIs
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org/api/v2

# Yandex Geocoder API
YANDEX_API_KEY=your_yandex_api_key_here
